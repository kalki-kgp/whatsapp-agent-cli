[Unit]
Description=Codex WhatsApp Gateway
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/.codex-whatsapp
Environment=PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin
Environment=HOME=%h
ExecStart=%h/.codex-whatsapp/venv/bin/python %h/.codex-whatsapp/server/gateway.py
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
